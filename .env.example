# MySQL (Prisma)
DATABASE_URL="mysql://user:pass@localhost:3306/convaire"

# Signing key for session JWTs (min 32 characters in production).
# You may use NEXTAUTH_SECRET instead if already set.
SESSION_SECRET="generate-a-long-random-string-at-least-32-chars"

# Public base URL of this app (scheme + host, no trailing slash). Required: Twilio
# rejects relative URLs for Call `url` / webhooks. Use your deployed https origin in
# production; for local testing with Twilio use ngrok (or similar) and set this to the
# ngrok https URL, not bare localhost (Twilio cannot reach your machine).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upstash Redis (REST) — durable campaign dial scheduling for large contact lists.
# Create a database at https://upstash.com and paste URL + token.
# UPSTASH_REDIS_REST_URL="https://xxxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# QStash — verify signed requests to /api/cron/campaign-dials (from QStash schedules).
# Copy Signing Keys from the QStash console. Set at least QSTASH_CURRENT_SIGNING_KEY;
# if QSTASH_NEXT_SIGNING_KEY is omitted, the app reuses the current key for verification.
# QSTASH_CURRENT_SIGNING_KEY="..."
# QSTASH_NEXT_SIGNING_KEY="..."

# Optional: Bearer / x-cron-secret for manual or non-QStash schedulers.
# CRON_SECRET="generate-a-long-random-string"

# Stripe — subscription billing and credit system.
# Create products/prices in the Stripe Dashboard, then paste keys here.
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_STARTER_PRICE_ID="price_..."
# STRIPE_BUSINESS_PRICE_ID="price_..."

# Optional: seed user password (prisma/seed.ts)
# SEED_USER_PASSWORD="your-secure-seed-password"
